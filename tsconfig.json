{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node", "vscode"],
    "strict": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "out",
    "moduleResolution": "node16",
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", ".vscode-test", "dist"]
}
