{
    "name": "foundry-devil-code-sight",
    "displayName": "Foundry Devil Code Sight",
    "description": "Connect to a running FoundryVTT instance via CDP for variable watching, JS scratchpad execution, and log streaming.",
    "version": "0.0.1",
    "publisher": "sylver",
    "license": "MIT",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Debuggers",
        "Notebooks",
        "Other"
    ],
    "main": "./dist/extension.js",
    "extensionDependencies": [
        "ms-toolsai.jupyter",
        "ms-edgedevtools.vscode-edge-devtools"
    ],
    "contributes": {
        "commands": [
            {
                "command": "foundryDevilCodeSight.connect",
                "title": "FoundryVTT: Connect via CDP"
            }
        ],
        "configuration": {
            "title": "Foundry Devil Code Sight",
            "properties": {
                "foundryDevilCodeSight.cdpHost": {
                    "type": "string",
                    "default": "localhost",
                    "description": "Hostname or IP of the CDP endpoint."
                },
                "foundryDevilCodeSight.cdpPort": {
                    "type": "number",
                    "default": 9222,
                    "description": "CDP remote debugging port."
                },
                "foundryDevilCodeSight.watchAutoRefreshInterval": {
                    "type": "number",
                    "default": 0,
                    "description": "Auto-refresh interval in ms for the variable watcher. 0 = disabled."
                }
            }
        }
    },
    "scripts": {
        "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "watch": "npm run compile -- --watch",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "dependencies": {
        "chrome-remote-interface": "^0.33.2"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/vscode": "^1.85.0",
        "@vscode/test-electron": "^2.3.8",
        "esbuild": "^0.20.0",
        "eslint": "^8.56.0",
        "typescript": "^5.3.3"
    }
}
